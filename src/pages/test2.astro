---
import RootLayout from "../layouts/RootLayout.astro"
import LiveFaithful from "../components/_test-live-faithful"
---

<RootLayout
  title="Astrolabe — faithful-style live data test"
  description="The Wikimedia plaque's rendering rules, ported to React and driven by live ATNF data."
  path="/test2"
>
  <div class="min-h-svh flex flex-col">
    <header class="flex items-center justify-between px-4 py-2 border-b border-foreground/10 shrink-0">
      <a href="/" class="text-[12px] text-foreground hover:text-foreground/70 transition" style="font-family: var(--font-display)">
        ASTROLABE
      </a>
      <span class="text-[9px] uppercase tracking-widest text-foreground/40">
        /test2 · rendering rules ported, live data
      </span>
      <div class="flex items-center gap-3 text-[10px]">
        <a href="/test" class="text-foreground/50 hover:text-foreground transition">← wikimedia trace</a>
        <a href="/" class="text-foreground/50 hover:text-foreground transition">home</a>
      </div>
    </header>
    <LiveFaithful client:only="react" />
  </div>
</RootLayout>
