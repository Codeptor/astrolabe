---
import RootLayout from "../layouts/RootLayout.astro"
---

<RootLayout title="not found · Astrolabe">
  <div class="flex min-h-svh flex-col items-center justify-center px-6 gap-6">
    <div class="flex flex-col items-center gap-2 text-center">
      <p class="text-[32px] leading-none text-foreground" style="font-family: var(--font-display)">
        404
      </p>
      <p class="text-[11px] text-foreground/60">
        no pulsar signal from this coordinate
      </p>
    </div>
    <a
      href="/"
      class="text-[10px] text-foreground/70 hover:text-foreground transition border border-foreground/20 hover:border-foreground/50 px-3 py-1.5"
    >
      ← back to astrolabe
    </a>
  </div>
</RootLayout>
