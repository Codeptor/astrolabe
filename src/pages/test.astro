---
import RootLayout from "../layouts/RootLayout.astro"
import paths from "../data/wikimedia-pulsars-paths.svg?raw"
---

<RootLayout
  title="Astrolabe — Wikimedia plaque test"
  description="1:1 render of the Pulsars group from the public-domain Wikimedia Commons Voyager Golden Record SVG — hand-traced from the NASA original."
  path="/test"
>
  <div class="min-h-svh flex flex-col">
    <header class="flex items-center justify-between px-4 py-2 border-b border-foreground/10 shrink-0">
      <a href="/" class="text-[12px] text-foreground hover:text-foreground/70 transition" style="font-family: var(--font-display)">
        ASTROLABE
      </a>
      <span class="text-[9px] uppercase tracking-widest text-foreground/40">
        /test · wikimedia pulsar map (NASA original trace)
      </span>
      <a href="/" class="text-[10px] text-foreground/50 hover:text-foreground transition">← back</a>
    </header>

    <main class="flex-1 min-h-0 flex items-center justify-center p-6">
      <svg
        viewBox="190 330 310 200"
        class="w-full max-w-[min(1600px,100%)] h-auto"
        preserveAspectRatio="xMidYMid meet"
        xmlns="http://www.w3.org/2000/svg"
        aria-label="Pioneer / Voyager pulsar map, traced 1:1 from Wikimedia Commons"
      >
        <g stroke="currentColor" stroke-width="0.8" stroke-linecap="round" fill="none">
          <Fragment set:html={paths} />
        </g>
      </svg>
    </main>

    <footer class="shrink-0 px-4 pb-3 text-[9px] text-foreground/45 leading-relaxed flex flex-wrap gap-2 justify-between">
      <span>
        source:
        <a
          href="https://commons.wikimedia.org/wiki/File:Voyager_Golden_Record_Cover_Explanation.svg"
          target="_blank"
          rel="noreferrer"
          class="underline decoration-foreground/25 hover:decoration-foreground hover:text-foreground transition"
        >
          Voyager_Golden_Record_Cover_Explanation.svg
        </a>
        · traced by BrianKrent from NASA/JPL public-domain original, 2010 (rev 2015)
      </span>
      <span>{paths.split('<path').length - 1} paths rendered verbatim</span>
    </footer>
  </div>
</RootLayout>
