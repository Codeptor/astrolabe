---
import "../styles/global.css"
import ThemeScript from "../components/ThemeScript.astro"

interface Props {
  title?: string
  description?: string
  path?: string
}

const {
  title = "Astrolabe — interactive Pioneer plaque pulsar map",
  description = "Pick any star in the galaxy and generate a Pioneer-plaque-style pulsar map for it. 14 best pulsars selected via GDOP, rendered in authentic 1972 line art with binary period encoding.",
  path = Astro.url.pathname,
} = Astro.props

const SITE = Astro.site?.toString().replace(/\/$/, "") ?? "https://astrolabe.bhanueso.dev"
const canonical = `${SITE}${path}`
const ogImage = `${SITE}/og.png`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0a0a10" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="Astrolabe" />
    <meta name="author" content="Bhanu" />
    <meta name="creator" content="Bhanu" />
    <meta name="publisher" content="Bhanu" />
    <meta
      name="keywords"
      content="pulsar map, pioneer plaque, voyager plaque, pulsar triangulation, galactic coordinates, ATNF, astronomy, data visualization"
    />
    <meta name="referrer" content="origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no, address=no, email=no" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="shortcut icon" href="/icon.svg" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Astrolabe" />

    <link
      rel="preload"
      href="/fonts/TronicaMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Nippo-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Astrolabe" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Pick any star in the galaxy and generate a Pioneer-plaque-style pulsar map for it."
    />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Astrolabe — interactive Pioneer plaque pulsar map"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta
      name="twitter:description"
      content="Pick any star in the galaxy and generate a Pioneer-plaque-style pulsar map for it."
    />
    <meta name="twitter:creator" content="@codeptor" />
    <meta name="twitter:image" content={ogImage} />

    <ThemeScript />
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {})
        })
      }
    </script>
  </head>
  <body class="min-h-svh antialiased" style="font-family: var(--font-mono)">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-2 focus:top-2 focus:z-[200] focus:bg-background focus:text-foreground focus:border focus:border-foreground/40 focus:px-3 focus:py-1.5 focus:text-[11px] focus:no-underline"
    >
      skip to main content
    </a>
    <slot />
  </body>
</html>
